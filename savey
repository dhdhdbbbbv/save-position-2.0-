local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local savedPosition = nil

-- GUI Setup
local gui = Instance.new("ScreenGui")
gui.Name = "TeleportGui"
gui.ResetOnSpawn = false
gui.Parent = playerGui

-- Save Button
local saveButton = Instance.new("TextButton")
saveButton.Size = UDim2.new(0, 180, 0, 40)
saveButton.Position = UDim2.new(0, 10, 0, 10)
saveButton.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
saveButton.TextColor3 = Color3.new(1, 1, 1)
saveButton.Font = Enum.Font.SourceSansBold
saveButton.TextSize = 20
saveButton.Text = "✅ Save Position"
saveButton.Parent = gui

-- Teleport Button
local tpButton = Instance.new("TextButton")
tpButton.Size = UDim2.new(0, 180, 0, 40)
tpButton.Position = UDim2.new(0, 10, 0, 60)
tpButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
tpButton.TextColor3 = Color3.new(1, 1, 1)
tpButton.Font = Enum.Font.SourceSansBold
tpButton.TextSize = 20
tpButton.Text = "🚀 Teleport to Saved"
tpButton.Parent = gui

-- Credit Label
local creditLabel = Instance.new("TextLabel")
creditLabel.Size = UDim2.new(0, 200, 0, 20)
creditLabel.Position = UDim2.new(0, 10, 1, -30)
creditLabel.BackgroundTransparency = 1
creditLabel.TextColor3 = Color3.new(1, 1, 1)
creditLabel.TextStrokeTransparency = 0.7
creditLabel.Font = Enum.Font.SourceSansItalic
creditLabel.TextSize = 14
creditLabel.TextXAlignment = Enum.TextXAlignment.Left
creditLabel.Text = "Made by robloxcool on Discord or Dhdhdbbbbbv on roblox "
creditLabel.Parent = gui

-- Save Position Handler
saveButton.MouseButton1Click:Connect(function()
	local character = player.Character or player.CharacterAdded:Wait()
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if hrp then
		savedPosition = hrp.Position
		saveButton.Text = "✅ Position Saved!"
		wait(1)
		saveButton.Text = "✅ Save Position"
	end
end)

-- Teleport Handler
tpButton.MouseButton1Click:Connect(function()
	local character = player.Character or player.CharacterAdded:Wait()
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if hrp and savedPosition then
		hrp.CFrame = CFrame.new(savedPosition)
	end
end)
